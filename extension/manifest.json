{
  "manifest_version": 3,
  "name": "Price Tracker",
  "version": "2.0.0",
  "description": "Track prices from Amazon, Flipkart, Reliance Digital and more. Get desktop notifications on price changes.",
  "permissions": ["sidePanel", "storage", "alarms", "notifications"],
  "host_permissions": ["<all_urls>"],
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "action": {
    "default_title": "Open Price Tracker",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
